{
  "name": "slurm-status-bar",
  "displayName": "Slurm Status Bar",
  "description": "Displays Slurm job status from ~/.slurm_status_bar.txt in the VS Code status bar with real-time updates",
  "version": "0.4.0",
  "publisher": "devon7y",
  "repository": {
    "type": "git",
    "url": "https://github.com/devon7y/vscode-slurm-status-bar.git"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^14.17.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "typescript": "^4.5.0"
  }
}
